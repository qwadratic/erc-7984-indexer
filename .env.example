CHAIN=sepolia                      # "sepolia" (default) or "local" (anvil + cleartext FHE)
PONDER_RPC_URL_31337=http://127.0.0.1:8545   # Local anvil RPC (used when CHAIN=local)
PONDER_RPC_URL_11155111=          # Sepolia archive RPC
TOKEN_ADDRESS=0x46208622DA27d91db4f0393733C8BA082ed83158
UNDERLYING_ADDRESS=0xff54739b16576FA5402F211D0b938469Ab9A5f3F
ACL_ADDRESS=0xf0Ffdc93b7E186bC2f8CB3dAA75D86d1930A433D
START_BLOCK=10162161              # cWETHMock deploy block (full token history)
UNDERLYING_START_BLOCK=10162161   # Underlying ERC-20 deploy block (defaults to START_BLOCK)
ACL_START_BLOCK=11150000          # ACL is network-wide busy — index our delegations from a recent block
MAX_RPS=5                         # Ponder max RPC requests/sec (free-tier Alchemy ~7; use ~5)
DECRYPT_RELAY_CONCURRENCY=10      # Decrypt worker: max concurrent relay decryption requests
PORT=42069                        # API port (default 42069, live instance 80)
INDEXER_PRIVATE_KEY=              # Indexer identity — INDEXER_ADDRESS derived in src/config.ts
DATABASE_URL=postgresql://user@localhost:5432/erc7984_indexer
